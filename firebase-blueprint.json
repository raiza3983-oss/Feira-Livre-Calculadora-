{
  "entities": {
    "Shop": {
      "title": "Shop",
      "description": "A vendor's shop in the market",
      "type": "object",
      "properties": {
        "ownerUid": { "type": "string" },
        "type": { "type": "string", "enum": ["feira", "barraca", "mercado", "atacado"] },
        "name": { "type": "string" }
      },
      "required": ["ownerUid", "type"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "User profile data",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["vendor", "customer"] },
        "name": { "type": "string" }
      },
      "required": ["uid", "email", "role"]
    },
    "SyncSession": {
      "title": "Sync Session",
      "description": "Sales history and inventory sync session keyed by PIN Token",
      "type": "object",
      "properties": {
        "pinToken": { "type": "string" },
        "feiranteName": { "type": "string" },
        "feiranteCnpj": { "type": "string" },
        "products": { "type": "array" },
        "salesHistory": { "type": "array" },
        "productsSmartMetadata": { "type": "object" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["pinToken", "feiranteName", "products", "salesHistory"]
    }
  },
  "firestore": {
    "/shops/{shopId}": {
      "schema": "Shop",
      "description": "Vendor shops"
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile information"
    },
    "/syncs/{pinToken}": {
      "schema": "SyncSession",
      "description": "Synced vendor data buckets"
    }
  }
}
